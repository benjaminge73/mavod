# ── Telegram ────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
# CSV des user ids Telegram autorisés. Vide/absent => personne autorisé (défaut sûr).
# Récupérer son id via un bot type @userinfobot.
TELEGRAM_ALLOWED_USERS=

# ── LLM (provider-agnostic, API OpenAI-compatible) ──────────────────────────
# LLM_PROVIDER choisit un preset (base_url + modèle par défaut). Presets connus :
#   deepseek | openai | mistral | groq | openrouter | xai | together | local
# LLM_MODEL / LLM_BASE_URL overrident le preset (requis pour un provider inconnu).
LLM_PROVIDER=deepseek
LLM_API_KEY=
LLM_MODEL=
LLM_BASE_URL=

# ── qBittorrent (remote, WebUI API) ─────────────────────────────────────────
QB_URL=
QB_USER=
QB_PASS=

# ── Indexer ─────────────────────────────────────────────────────────────────
PROWLARR_URL=
PROWLARR_API_KEY=
